@page "/service/details/{id:guid}"
@model DetailsModel

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Service Detail Start -->
            <div class="mb-5">
                @if (Model.ServiceDetails != null)
                {
                    <!-- Image Section -->
                    <img class="img-fluid w-100 rounded mb-5 shadow-sm" src="https://i.ytimg.com/vi/KGv9J_cAnTE/hq720.jpg?sqp=-oaymwEhCK4FEIIDSFryq4qpAxMIARUAAAAAGAElAADIQj0AgKJD&rs=AOn4CLCWTy88d4xsrpGgfLU1ZMfP8jnB0g" alt="Service Image">

                    <!-- Title and Description -->
                    <h1 class="mb-4 text-dark font-weight-bold">@Model.ServiceDetails.Name</h1>
                    <p class="text-muted">
                        At our veterinary service center, we provide top-notch care for your beloved pets. Our @Model.ServiceDetails.Name service ensures that your pet receives the specialized attention it deserves. With years of experience in handling a wide range of animal health issues, we have designed this service to meet your pet’s unique needs with care and precision.
                    </p>

                    <p class="text-muted">
                        Our dedicated team of veterinarians and support staff is here to provide comprehensive @Model.ServiceDetails.Name services, from initial consultation to complete care. We use state-of-the-art medical equipment and the latest treatment techniques to ensure your pet’s health and well-being.
                    </p>

                    <p class="text-muted">
                        Whether it's a routine checkup, surgery, or emergency care, we treat every pet like family. Our service includes everything from initial diagnosis to follow-up care, ensuring that your pet gets the best possible treatment every step of the way.
                    </p>

                    <p class="text-muted">
                        Trust us to provide compassionate, expert care for your pets. We're passionate about animal welfare and strive to exceed your expectations at every visit. Book your @Model.ServiceDetails.Name service today and ensure your pet stays happy and healthy!
                    </p>

                    <!-- Service Information Table -->
                    <div class="service-details mt-4">
                        <h3 class="text-dark font-weight-bold mb-4">@Model.ServiceDetails.Name</h3>

                        <table class="table service-info-table">
                            <tbody>
                                <tr>
                                    <th scope="row">Description</th>
                                    <td>@Model.ServiceDetails.Description</td>
                                </tr>
                                <tr>
                                    <th scope="row">Price</th>
                                    <td>$@Model.ServiceDetails.BasePrice</td>
                                </tr>
                                <tr>
                                    <th scope="row">Duration</th>
                                    <td>@Model.ServiceDetails.Duration</td>
                                </tr>
                                <tr>
                                    <th scope="row">Available From</th>
                                    <td>@Model.ServiceDetails.AvailableFrom.ToString("MM/dd/yyyy")</td>
                                </tr>
                                <tr>
                                    <th scope="row">Available To</th>
                                    <td>@Model.ServiceDetails.AvailableTo.ToString("MM/dd/yyyy")</td>
                                </tr>
                                <tr>
                                    <th scope="row">Travel Cost</th>
                                    <td>$@Model.ServiceDetails.TravelCost</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                }
                else if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">
                        @Model.ErrorMessage
                    </div>
                }
                else
                {
                    <p class="text-muted">Loading...</p>
                }
            </div>

            <!-- Appointment Form -->
            @await Component.InvokeAsync("AppointmentForm")

            <!-- Service Detail End -->
            <div class="text-center mt-4">
                <a href="/" class="btn btn-primary">Go Back to Services</a>
            </div>
        </div>
    </div>
</div>

<!-- Add the CSS style directly inside the page -->
<style>


    .service-details {
        margin-top: 2rem;
    }

    /* Table Styling */
    .service-info-table {
        width: 100%;
        border-collapse: collapse;
        background-color: #fafafa;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
    }

        .service-info-table th, .service-info-table td {
            padding: 12px 16px;
            text-align: left;
        }

        /* Table Header Styling */
        .service-info-table th {
            background-color: #f5f5f5;
            font-weight: bold;
            color: #333;
            width: 30%;
            border-bottom: 1px solid #e0e0e0;
        }

        /* Table Data Styling */
        .service-info-table td {
            color: #555;
            border-bottom: 1px solid #e0e0e0;
        }

        /* Last row shouldn't have a border-bottom */
        .service-info-table tr:last-child td {
            border-bottom: none;
        }
    /* General Container and Layout */
    .container {
        max-width: 95%;
        margin: 0 auto;
    }

    .row {
        display: flex;
        justify-content: center;
    }

    .col-lg-8 {
        padding: 0 15px;
    }

    /* Image Styling */
    .img-fluid {
        border-radius: 8px;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
    }

    /* Text Styling */
    h1, h3 {
        font-family: 'Arial', sans-serif;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    p {
        font-family: 'Arial', sans-serif;
        font-size: 1rem;
        line-height: 1.7;
        color: #555;
    }

    .text-muted {
        color: #666;
    }

    /* Button Styles */
    .btn-primary {
        background-color: #007bff;
        border-color: #007bff;
        padding: 12px 20px;
        font-size: 1rem;
        border-radius: 6px;
        transition: background-color 0.3s ease;
    }

        .btn-primary:hover {
            background-color: #0056b3;
            border-color: #0056b3;
        }

    /* Service Details */
    .service-details {
        font-size: 1.1rem;
        line-height: 1.6;
    }

        .service-details p {
            margin-bottom: 1rem;
        }

        .service-details h3 {
            color: #333;
        }

    /* Link Styling for Navigation */
    a.btn-primary {
        text-decoration: none;
        display: inline-block;
    }

    /* Box Shadows */
    .shadow-sm {
        box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.05);
    }

</style>

